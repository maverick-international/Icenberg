{
    "name": "mvrk/icenberg",
    "type": "library",
    "description": "Abstraction Library for Advanced Custom Fields",
    "license": "MIT",
    "keywords": [
        "acf",
        "advanced custom fields",
        "wordpress"
    ],
    "authors": [
        {
            "name": "Daniel Devine",
            "email": "dan.devine@maverick-intl.com"
        },
        {
            "name": "Cathal Toomey",
            "email": "cathal.toomey@maverick-intl.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "symfony/yaml": "^7.2"
    },
    "autoload": {
        "psr-4": {
            "MVRK\\Icenberg\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "symfony/var-dumper": "^5.1"
    }
}
